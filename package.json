{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "yarn && concurrently -k -r \"next dev -p 3000\" \"agentation-mcp server\"",
    "mcp": "agentation-mcp server",
    "build": "next build && rm -rf build && mv .next-build build",
    "start": "npx -y serve build",
    "export": "yarn build && touch ./build/.nojekyll",
    "deploy": "yarn install --frozen-lockfile && yarn export",
    "preinstall": "npx only-allow yarn"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "leaflet-gesture-handling": "^1.2.2",
    "lucide-react": "^0.553.0",
    "motion": "^12.7.4",
    "next": "15.5.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/leaflet": "^1.9.21",
    "@types/node": "25.5.0",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "agentation": "^3.0.2",
    "agentation-mcp": "^1.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.1.7",
    "eslint-import-resolver-typescript": "^3.9.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "only-allow": "^1.2.1",
    "postcss": "^8.4.28",
    "prettier": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.4.5"
  }
}
